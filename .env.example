# ── PocketBase backend ──────────────────────────────────────────────
PB_VERSION=0.22.20
PB_PORT=8094
# Homelab: reuse the existing live data dir so no data is moved.
# Cloud: use a host path or a named volume mount point.
PB_DATA_DIR=/mnt/user/appdata/pocketbase-reunion/data
PB_CONTAINER=pocketbase-reunion

# ── Cloudflare tunnel (homelab ingress only; from 1Password) ────────
CF_TUNNEL_ID=
CF_TUNNEL_SECRET=
CF_ACCOUNT_TAG=
API_HOSTNAME=reunion-api.klsll.com
# Optional: allow Apple auth handoff back to local dev frontends.
# Example: DEV_FRONTEND_URLS=http://192.168.20.60:4173,http://localhost:4173
DEV_FRONTEND_URLS=

# ── gedcom_sync (admin import; see tools/gedcom_sync/README.md) ─────
PB_URL=http://192.168.20.14:8094
PB_ADMIN_EMAIL=james@klsll.com
PB_ADMIN_PASSWORD=
WT_DB_HOST=webtrees-db
WT_DB_NAME=webtrees
WT_DB_USER=webtrees
WT_DB_PASSWORD=
